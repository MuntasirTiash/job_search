# Anthropic
ANTHROPIC_API_KEY=

# GitHub (for fetching your repos to tailor resume)
GITHUB_TOKEN=
GITHUB_USERNAME=

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Gmail OAuth2 — main account (label-only, no delete)
GMAIL_CREDENTIALS_PATH=credentials/gmail_oauth.json

# Dedicated job application email (used for portal account creation)
JOB_EMAIL=yourname.jobs@gmail.com
JOB_EMAIL_CREDENTIALS_PATH=credentials/job_gmail_oauth.json

# Hunter.io — recruiter email lookup (free tier: 25 searches/month)
HUNTER_API_KEY=

# Optional: Langfuse observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
